{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "5.0",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@gitgud/shared": ["packages/shared/src/index.ts"],
      "@gitgud/shared/*": ["packages/shared/src/*"],
      "@gitgud/database": ["packages/database/src/index.ts"],
      "@gitgud/database/*": ["packages/database/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
