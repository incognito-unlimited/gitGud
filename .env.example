# Backend services
# Put this in apps/auth-lobby-service/.env and apps/game-engine-service/.env when running them directly,
# or export these values in your terminal before starting the workspace.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=gitgud-dev-secret
AUTH_LOBBY_PORT=4101
GAME_ENGINE_PORT=4102

# GitHub OAuth — only required for the deployed environment (or optional local OAuth testing)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4101/auth/github/callback

# AI Agent Service & Keys
GEMINI_API_KEY=
GROQ_API_KEY=
AI_AGENT_SERVICE_URL=http://localhost:8001

# Frontend
# Put this in apps/frontend/.env.local if you want to override the defaults.
VITE_AUTH_API_URL=http://localhost:4101
VITE_GAME_API_URL=http://localhost:4102
VITE_GAME_SOCKET_URL=http://localhost:4102
VITE_ENABLE_GITHUB_OAUTH=false

# Notes
# By default in local development, VITE_ENABLE_GITHUB_OAUTH is set to false, and authentication uses dev-login (/auth/dev-login).
# GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET are only required for the deployed production environment (or when testing real GitHub OAuth locally).
# In production (NODE_ENV=production), /auth/dev-login is disabled and returns 403 Forbidden.